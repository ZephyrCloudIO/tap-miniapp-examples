{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "name", "execution", "states"],
  "properties": {
    "id": { "const": "examples-unofficial-suno-player-manual-brief" },
    "name": { "type": "string", "minLength": 1 },
    "execution": { "const": "dag" },
    "states": {
      "type": "object",
      "required": ["checkpoint", "ready"]
    }
  }
}
